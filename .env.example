# Supabase (safe to expose — anon/publishable key is RLS-protected)
VITE_SUPABASE_URL=https://your-project.supabase.co
VITE_SUPABASE_ANON_KEY=sb_publishable_xxx

# NOTE: The Gemini API key is NOT stored here. It lives only in Supabase
# Edge Function secrets (set with: supabase secrets set GEMINI_API_KEY=...).
# The browser never sees it.
